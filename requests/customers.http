### Customer API Requests
# This file contains HTTP requests for testing Customer endpoints.
# You can use the REST Client extension in VS Code to run these.

@baseUrl = http://localhost:8000/api/v1
@authToken = YOUR_BEARER_TOKEN_HERE
@customerId = 1

### 1. Get All Customers
# Returns a list of all customers with their order history.
GET {{baseUrl}}/customers
Authorization: Bearer {{authToken}}
Accept: application/json

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Customers fetched successfully",
#   "data": [
#     {
#       "id": 1,
#       "firstName": "John",
#       "lastName": "Doe",
#       "email": "john.doe@example.com",
#       "phone": "+1234567890",
#       "address": "123 Main St, Anytown, USA",
#       "businessName": "John's Store",
#       "customerType": "retail",
#       "loyaltyPoints": 0,
#       "createdAt": "2026-03-15 17:00:00",
#       "updatedAt": "2026-03-15 17:30:00",
#       "orders": [
#         {
#           "id": 1,
#           "orderNumber": "ORD-A1B2C3D4",
#           "status": "completed",
#           "discountedTotalPrice": 150.00,
#           "createdAt": "2026-03-15 17:15:00"
#         }
#       ]
#     }
#   ]
# }


### 2. Get Single Customer
# Returns detailed information about a specific customer including orders and refunds.
GET {{baseUrl}}/customers/{{customerId}}
Authorization: Bearer {{authToken}}
Accept: application/json

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Customer fetched successfully",
#   "data": {
#     "id": 1,
#     "firstName": "John",
#     "lastName": "Doe",
#     "email": "john.doe@example.com",
#     "phone": "+1234567890",
#     "address": "123 Main St, Anytown, USA",
#     "businessName": "John's Store",
#     "customerType": "retail",
#     "loyaltyPoints": 0,
#     "createdAt": "2026-03-15 17:00:00",
#     "updatedAt": "2026-03-15 17:30:00",
#     "orders": [
#       {
#         "id": 1,
#         "orderNumber": "ORD-A1B2C3D4",
#         "status": "completed",
#         "discountedTotalPrice": 150.00,
#         "createdAt": "2026-03-15 17:15:00"
#       }
#     ],
#     "refunds": []
#   }
# }


### 3. Create Customer
# Creates a new customer record. Supports combined 'name' field.
POST {{baseUrl}}/customers
Authorization: Bearer {{authToken}}
Content-Type: application/json
Accept: application/json

{
    "name": "John Doe",
    "email": "john.doe@example.com",
    "phone": "+1234567890",
    "address": "123 Main St, Anytown, USA",
    "businessName": "John's Store",
    "customerType": "retail"
}

# Expected Response: 201 Created
# {
#   "success": true,
#   "message": "Customer created successfully",
#   "data": {
#     "firstName": "John",
#     "lastName": "Doe",
#     "email": "john.doe@example.com",
#     "phone": "+1234567890",
#     "address": "123 Main St, Anytown, USA",
#     "businessName": "John's Store",
#     "customerType": "retail",
#     "id": 2
#   }
# }


### 4. Update Customer
# Updates an existing customer record.
PUT {{baseUrl}}/customers/{{customerId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json
Accept: application/json

{
    "name": "John Updated",
    "email": "john.updated@example.com",
    "phone": "+1987654321",
    "address": "456 Side St, Othertown, USA",
    "businessName": "John's New Store",
    "customerType": "retail"
}

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Customer updated successfully",
#   "data": {
#     "id": 1,
#     "firstName": "John",
#     "lastName": "Updated",
#     "email": "john.updated@example.com",
#     "phone": "+1987654321",
#     "address": "456 Side St, Othertown, USA",
#     "businessName": "John's New Store",
#     "customerType": "retail",
#     "loyaltyPoints": 0
#   }
# }


### 5. Delete Customer
# Deletes a customer. Only allowed if they have no active orders.
# Requires CEO or Manager role.
DELETE {{baseUrl}}/customers/{{customerId}}
Authorization: Bearer {{authToken}}
Accept: application/json

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Customer deleted successfully"
# }
