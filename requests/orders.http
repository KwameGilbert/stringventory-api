### 3a. Create Order (With Discount & Partial Fulfillment)
# Creates a new order. Stock is automatically deducted from inventory.
POST {{baseUrl}}/orders
Authorization: Bearer {{authToken}}
Content-Type: application/json
Accept: application/json

{
    "customerId": 1,
    "paymentMethod": "cash",
    "discountCode": "SAVE10",
    "notes": "Deliver to the front desk",
    "items": [
        {
            "productId": 1,
            "quantity": 100,
            "fulfilledQuantity": 40
        }
    ]
}

# Expected Response: 201 Created
# {
#   "success": true,
#   "message": "Order created successfully",
#   "data": {
#     "id": 5,
#     "orderNumber": "ORD-E5F6G7H8",
#     "customerId": 1,
#     "status": "partially_fulfilled",
#     "discountId": 2,
#     "discountType": "percentage",
#     "discountPercentage": 10,
#     "discountAmount": 10.00,
#     "discountedPrice": 100.00,
#     "discountedTotalPrice": 90.00,
#     "notes": "Deliver to the front desk",
#     "createdAt": "2026-03-15 17:45:00",
#     "updatedAt": "2026-03-15 17:45:00",
#     "items": [
#       {
#         "id": 10,
