### 3b. Create Order (No Discount, Full Fulfillment)
POST {{baseUrl}}/orders
Authorization: Bearer {{authToken}}
Content-Type: application/json
Accept: application/json

{
    "customerId": 1,
    "paymentMethod": "momo",
    "items": [
        {
            "productId": 2,
            "quantity": 5,
            "fulfilledQuantity": 5
        }
    ]
}

# Expected Response: 201 Created
# {
#   "success": true,
#   "message": "Order created successfully",
#   "data": {
#     "id": 6,
#     "orderNumber": "ORD-J9K0L1M2",
#     "status": "completed",
#     "discountAmount": 0.00,
#     "discountedTotalPrice": 50.00,
#     "items": [...]
#   }
# }

### 4. Fulfill Order Item (Partial or Full)
# Use this to track when a customer takes their remaining items.
# Quantity to fulfill must be <= remaining unfulfilled quantity.
POST {{baseUrl}}/orders/item/{{orderItemId}}/fulfill
Authorization: Bearer {{authToken}}
Content-Type: application/json
Accept: application/json

{
    "quantity": 30
}

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Successfully fulfilled 30 units",
#   "data": {
#     "id": 1,
#     "orderId": 1,
#     "productId": 1,
#     "quantity": 100,
#     "fulfilledQuantity": 70,
#     "fulfillmentStatus": "partial",
#     "totalPrice": 1000.00
#   }
# }

### 5. Cancel Order
# Reverses inventory and cancels transactions.
# Only allowed for CEO/Manager roles.
POST {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{authToken}}
Accept: application/json

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Order cancelled and stock returned successfully"
# }
