### Order API Requests
# This file contains HTTP requests for testing Order endpoints.

@baseUrl = http://localhost:8000/api/v1
@authToken = YOUR_BEARER_TOKEN_HERE
@orderId = 1
@orderItemId = 1

### 1. Get All Orders
# Returns all orders with customers, items, discounts, and transactions.
GET {{baseUrl}}/orders
Authorization: Bearer {{authToken}}
Accept: application/json

# Expected Response: 200 OK
# {
#   "success": true,
#   "message": "Orders fetched successfully",
#   "data": [
#     {
#       "id": 1,
#       "orderNumber": "ORD-A1B2C3D4",
#       "customerId": 1,
#       "status": "completed",
#       "discountId": 2,
